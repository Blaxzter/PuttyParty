{
  "name": "putt-party",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Putt Party — live mini-golf tournament leaderboard on Cloudflare Workers",
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "dev": "npm run build:client && wrangler dev",
    "deploy": "npm run build:client && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply puttparty-db --local",
    "db:migrate": "wrangler d1 migrations apply puttparty-db --remote",
    "db:seed:local": "wrangler d1 execute puttparty-db --local --file=./scripts/seed.sql",
    "db:seed": "wrangler d1 execute puttparty-db --remote --file=./scripts/seed.sql",
    "db:reset:local": "npm run db:migrate:local && npm run db:seed:local",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@paulmillr/qr": "^0.2.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.9.0",
    "htmx.org": "^2.0.4",
    "jose": "^6.0.11",
    "nanoid": "^5.1.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20250601.0",
    "drizzle-kit": "^0.31.2",
    "esbuild": "^0.25.5",
    "partysocket": "^1.1.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.100.0"
  }
}
